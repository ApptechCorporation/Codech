    <!--            android:defaultValue="false"-->
    <!--            android:iconSpaceReserved="false"-->
    <!--            android:key="experimental_kotlin_completions"-->
    <!--            app:iconSpaceReserved="false"-->
    <!--            android:title="@string/settings_kotlin_completions"-->
    <!--            android:summary="@string/settings_kotlin_completions_desc"/>-->
    <!--    </PreferenceCategory>-->
    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/completion_settings_java_title">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            android:key="code_editor_error_highlight"
            android:title="@string/code_editor_error_highlight"/>
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:iconSpaceReserved="false"
            android:key="code_editor_completion"
            app:iconSpaceReserved="false"
            android:title="@string/settings_code_completions"/>
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:iconSpaceReserved="false"
            android:key="java_case_insensitive_match"
            app:iconSpaceReserved="false"
            app:defaultValue="false"
            app:summary="@string/settings_case_insensitive_match_desc"
            app:title="@string/settings_case_insensitive_match_title"/>
    </PreferenceCategory>
    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/completion_settings_kotlin_title">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            android:key="kotlin_error_highlight"
            android:title="@string/code_editor_error_highlight"/>
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:iconSpaceReserved="false"
            android:key="kotlin_completion"
            app:iconSpaceReserved="false"
            android:title="@string/settings_code_completions"/>
        <SwitchPreferenceCompat
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            android:enabled="false"
            android:key="fast_kotlin_lsp"
            android:title="@string/use_fast_kotlin_lsp_title"
            android:summary="@string/use_fast_kotlin_lsp_desc"/>
        <EditTextPreference
            app:iconSpaceReserved="false"
            android:dialogTitle="@string/kotlin_max_items_count_title"
            android:defaultValue="50"
            android:inputType="numberDecimal"
            android:digits="0123456789"
            android:title="@string/kotlin_max_items_count_title"
            android:summary="@string/kotlin_max_items_count_summary"
            android:key="kotlin_max_items_count"
            android:dialogMessage="@string/kotlin_max_items_count_message"
            android:negativeButtonText="@android:string/cancel"
            android:positiveButtonText="@android:string/ok"/>
        <EditTextPreference
            app:iconSpaceReserved="false"
            android:dialogTitle="@string/parallel_backend_threads_title"
            android:defaultValue="10"
            android:inputType="numberDecimal"
            android:digits="0123456789"
            android:title="@string/parallel_backend_threads_title"
            android:summary="@string/parallel_backend_threads_summary"
            android:key="parallel_backend_threads"
            android:dialogMessage="@string/parallel_backend_threads_message"
            android:negativeButtonText="@android:string/cancel"
            android:positiveButtonText="@android:string/ok"/>
    </PreferenceCategory>
    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/editor_settings_title">
        <EditTextPreference
            app:iconSpaceReserved="false"
            android:dialogTitle="@string/font_size_title"
            android:defaultValue="14"
            android:inputType="numberDecimal"
            android:digits="0123456789"
            android:title="@string/font_size_title"
            android:summary="@string/font_size_summary"
            android:key="font_size"
            android:dialogMessage="@string/font_size_message"
            android:negativeButtonText="@android:string/cancel"
            android:positiveButtonText="@android:string/ok"/>
        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:defaultValue="false"
            app:title="@string/editor_settings_wordwrap"
            app:key="editor_wordwrap"/>
        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:defaultValue="false"
            app:title="@string/editor_delete_whitespaces"
            app:key="editor_delete_whitespaces"/>
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:iconSpaceReserved="false"
            android:key="diagnostic_detail"
            app:iconSpaceReserved="false"
            android:title="@string/diagnostic_detail_title"
            android:summary="@string/diagnostic_detail_desc"/>  
        <Preference
            app:key="scheme"
            app:iconSpaceReserved="false"
            app:title="@string/editor_scheme_title"
            app:summary="@string/editor_scheme_desc"/>
    </PreferenceCategory>
    <PreferenceCategory
        app:iconSpaceReserved="false"
        android:title="@string/editor_tabs_settings_title">
        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:defaultValue="true"
            app:title="@string/editor_tab_unique_file_name"
            app:summary="@string/editor_tab_unique_file_name_summary"
            app:key="editor_tab_unique_file_name"/>
    </PreferenceCategory>
</PreferenceScreen>